@charset "utf-8";

body { backface-visibility: hidden; }

.animated { animation-duration: 1s; animation-fill-mode: both; }

.animated.hinge { animation-duration: 2s; }

@-webkit-keyframes flash {=20
  0%, 50%, 100% { opacity: 1; }
  25%, 75% { opacity: 0; }
}

@keyframes flash {=20
  0%, 50%, 100% { opacity: 1; }
